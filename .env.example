SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key

# --- hCaptcha (Stripe セキュリティチェックリスト: 不正ログイン対策) ---
# 1) hcaptcha.com で site key / secret key を発行
# 2) Supabase Dashboard > Auth > Bot Protection で secret を登録
# 3) 下記 HCAPTCHA_SITE_KEY にクライアント用 site key を設定すると
#    Flutter のログイン/サインアップ画面に hCaptcha ウィジェットが表示される
HCAPTCHA_SITE_KEY=

# --- Edge Functions 用 (Supabase Dashboard の Functions Secrets に登録) ---
# RESEND_API_KEY              ログイン通知メール送信用
# LOGIN_NOTIFICATION_FROM     送信元アドレス (例: no-reply@yourdomain.com)
# APP_NAME                    通知メール件名に使うアプリ名
# HCAPTCHA_SECRET_KEY         Supabase Auth の captcha 検証用 (Dashboard 側にも設定)
